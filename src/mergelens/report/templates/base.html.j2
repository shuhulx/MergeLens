<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"
            integrity="sha384-bMFlhIPlnxNiDVbJnOsaREdZGeYul/yrInxSBRKOqu6k3oT/MUN3FZwKEVIeJu7C"
            crossorigin="anonymous"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f5f5f5; color: #333; line-height: 1.6;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        header {
            background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%);
            color: white; padding: 30px 0; text-align: center; margin-bottom: 30px;
        }
        header h1 { font-size: 2em; margin-bottom: 5px; }
        header p { opacity: 0.8; font-size: 1.1em; }
        .card {
            background: white; border-radius: 12px; padding: 24px;
            margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .card h2 {
            font-size: 1.3em; margin-bottom: 16px; color: #1a237e;
            border-bottom: 2px solid #e3f2fd; padding-bottom: 8px;
        }
        .mci-hero {
            text-align: center; padding: 20px;
            background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
            border-radius: 12px;
        }
        .mci-score { font-size: 4em; font-weight: bold; }
        .mci-verdict { font-size: 1.3em; text-transform: uppercase; margin-top: 5px; }
        .chart-container { min-height: 200px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 24px; }
        table {
            width: 100%; border-collapse: collapse; font-size: 0.9em;
        }
        th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f5f5f5; font-weight: 600; position: sticky; top: 0; }
        .table-scroll { max-height: 500px; overflow-y: auto; }
        .badge {
            display: inline-block; padding: 2px 8px; border-radius: 4px;
            font-size: 0.8em; font-weight: 600; text-transform: uppercase;
        }
        .badge-green { background: #e8f5e9; color: #2e7d32; }
        .badge-yellow { background: #fff3e0; color: #e65100; }
        .badge-red { background: #ffebee; color: #c62828; }
        .strategy-yaml {
            background: #263238; color: #aed581; padding: 16px;
            border-radius: 8px; font-family: 'Fira Code', monospace;
            font-size: 0.85em; overflow-x: auto; white-space: pre;
        }
        footer {
            text-align: center; padding: 20px; color: #999; font-size: 0.85em;
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <h1>{{ title }}</h1>
            <p>Pre-merge diagnostic report generated by MergeLens</p>
        </div>
    </header>
    <div class="container">
        {% if compare %}
        <!-- MCI Score -->
        <div class="card mci-hero">
            <div id="mci-gauge" class="chart-container"></div>
        </div>

        <!-- MCI Components -->
        {% if compare.mci.components %}
        <div class="card">
            <h2>MCI Components</h2>
            <table>
                <thead><tr><th>Component</th><th>Score</th></tr></thead>
                <tbody>
                {% for name, score in compare.mci.components.items() %}
                <tr><td>{{ name }}</td><td>{{ "%.4f"|format(score) }}</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- Similarity Heatmap -->
        <div class="card">
            <h2>Weight Similarity Heatmap</h2>
            <div id="heatmap-chart" class="chart-container"></div>
        </div>

        <!-- Spectral Dashboard -->
        <div class="card">
            <h2>Spectral Analysis Dashboard</h2>
            <div id="spectral-chart" class="chart-container"></div>
        </div>

        <!-- Conflict Zones -->
        {% if compare.conflict_zones %}
        <div class="card">
            <h2>Conflict Zone Analysis</h2>
            <div id="conflict-chart" class="chart-container"></div>
            <div class="table-scroll" style="margin-top: 16px;">
                <table>
                    <thead>
                        <tr><th>Zone</th><th>Layers</th><th>Severity</th><th>Avg Cos Sim</th><th>Recommendation</th></tr>
                    </thead>
                    <tbody>
                    {% for zone in compare.conflict_zones %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td>{{ zone.start_layer }}-{{ zone.end_layer }}</td>
                        <td><span class="badge badge-{{ 'red' if zone.severity.value in ['high', 'critical'] else 'yellow' if zone.severity.value == 'medium' else 'green' }}">{{ zone.severity.value }}</span></td>
                        <td>{{ "%.4f"|format(zone.avg_cosine_sim) }}</td>
                        <td>{{ zone.recommendation }}</td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        <!-- Layer Metrics Table -->
        <div class="card">
            <h2>Layer Metrics</h2>
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Layer</th><th>Type</th><th>Cosine Sim</th>
                            <th>L2 Dist</th><th>Spectral</th><th>Rank Ratio</th><th>Energy</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for m in compare.layer_metrics %}
                    <tr>
                        <td style="font-size: 0.8em;">{{ m.layer_name }}</td>
                        <td>{{ m.layer_type.value }}</td>
                        <td>{{ "%.4f"|format(m.cosine_similarity) }}</td>
                        <td>{{ "%.4f"|format(m.l2_distance) }}</td>
                        <td>{{ "%.4f"|format(m.spectral_overlap) if m.spectral_overlap is not none else '—' }}</td>
                        <td>{{ "%.4f"|format(m.effective_rank_ratio) if m.effective_rank_ratio is not none else '—' }}</td>
                        <td>{{ "%.4f"|format(m.task_vector_energy) if m.task_vector_energy is not none else '—' }}</td>
                    </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Strategy Recommendation -->
        {% if compare.strategy %}
        <div class="card">
            <h2>Strategy Recommendation</h2>
            <p><strong>Method:</strong> {{ compare.strategy.method.value }}
               ({{ "%.0f"|format(compare.strategy.confidence * 100) }}% confidence)</p>
            <p>{{ compare.strategy.reasoning }}</p>
            {% if compare.strategy.warnings %}
            <ul style="color: #e65100; margin: 10px 0;">
            {% for w in compare.strategy.warnings %}
                <li>{{ w }}</li>
            {% endfor %}
            </ul>
            {% endif %}
            <h3 style="margin: 16px 0 8px;">MergeKit Config</h3>
            <div class="strategy-yaml">{{ compare.strategy.mergekit_yaml }}</div>
        </div>
        {% endif %}
        {% endif %}
    </div>
    <footer>
        Generated by MergeLens — Pre-merge diagnostics for LLM model merging
    </footer>
    <script>
        {% for chart_id, chart_data in charts_json.items() %}
        try {
            var spec_{{ chart_id }} = {{ chart_data }};
            Plotly.newPlot(
                '{{ chart_id }}-{{ "gauge" if chart_id == "mci" else "chart" }}',
                spec_{{ chart_id }}.data,
                spec_{{ chart_id }}.layout,
                {responsive: true}
            );
        } catch(e) { console.warn('Chart {{ chart_id }} skipped:', e); }
        {% endfor %}
    </script>
</body>
</html>
